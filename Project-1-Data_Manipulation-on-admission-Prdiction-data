   "source": [
    "#34 Create a new column GRE_Level = “High” if GRE ≥ 320 else “Low”.\n",
    "df['GRE_Level']=df['gre score'].apply(lambda x:'High' if x>=320 else 'Low')"
   ]
  },
  {
